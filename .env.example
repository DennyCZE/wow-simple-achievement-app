# Battle.net API credentials — create a client at https://develop.battle.net/
# (Service URL can be left blank; check "I do not have a service URL".)
BNET_CLIENT_ID=
BNET_CLIENT_SECRET=

# Cache TTL for character achievement responses, in seconds.
# OAuth tokens are cached separately for 23h regardless of this value.
CACHE_TTL=3600

# Host port the container binds to on 127.0.0.1.
# Pick anything free; host nginx (in prod) or your browser (locally) talks to this.
HOST_PORT=8089

# Optional: value for the Access-Control-Allow-Origin response header.
# Leave empty to omit the header entirely (fine when frontend and API are same-origin).
ALLOWED_ORIGIN=
